@ARTICLE{Grusauskaite2026-po,
  title        = {“We, the conspiracy theorists.” How people do symbolic
                  boundary work in the “Great Reset” debates across social media
                  platforms},
  author       = {Grusauskaite, Kamile and De Bondt, Matthias and de Wildt, Lars
                  and Aupers, Stef},
  journaltitle = {New Media Soc.},
  publisher    = {SAGE Publications},
  issue        = {14614448261446590},
  date         = {2026-05-19},
  abstract     = {Conspiracy theories spread rapidly on social media. A growing
                  field of research has examined how social media platforms
                  shape conspiracy narratives and cultures. However, this
                  technological focus has largely overshadowed social media
                  users’ own agency toward collective identity construction.
                  This article examines how users in online conspiracy
                  communities construct collective identities through symbolic
                  boundary work. Focusing on discussions surrounding the “Great
                  Reset” conspiracy theory, across six major social media
                  platforms (Facebook, Instagram, Twitter/X, YouTube, Reddit,
                  and TikTok), we use multimodal discourse analysis to analyze
                  630 posts and their comments. Our findings reveal that users
                  do symbolic boundary work by defining themselves as “critical
                  thinkers,” reclaiming the label “conspiracy theorist,” and
                  affectively transforming personal struggles into shared
                  narratives, creating a shared identity in contrast to the
                  “mainstream other.” The study contributes to research on
                  social media and conspiracy cultures by foregrounding identity
                  over content, offering insight into how users build solidarity
                  online.},
  language     = {en}
}

