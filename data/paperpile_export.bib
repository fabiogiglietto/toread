  language     = {en}
}

@ARTICLE{Inacio-da-Silva2026-zf,
  title        = {Identifying potentially irregular electoral ads in Facebook
                  during the Brazilian elections},
  author       = {Inacio da Silva, Marcio and de Oliveira, Lucas and Vaz de
