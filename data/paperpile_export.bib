  eprinttype   = {arXiv},
  eprintclass  = {cs.CL},
  abstract     = {Large language models (LLMs) have raised hopes for automated
                  end-to-end fact-checking, but prior studies report mixed
                  results. As mainstream chatbots increasingly ship with
                  reasoning capabilities and web search tools -- and millions of
                  users already rely on them for verification -- rigorous
                  evaluation is urgent. We evaluate 15 recent LLMs from OpenAI,
