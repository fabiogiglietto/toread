  issue        = {6777},
  pages        = {eaea3884},
  date         = {2025-12-04},
  abstract     = {There are widespread fears that conversational artificial
                  intelligence (AI) could soon exert unprecedented influence
                  over human beliefs. In this work, in three large-scale
                  experiments (N = 76,977 participants), we deployed 19 large
                  language models (LLMs)-including some post-trained explicitly
