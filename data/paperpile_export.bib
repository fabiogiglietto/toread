@ARTICLE{Richter2026-bt,
  title        = {Who’s driving the {AI} hype in its formative phase? A
                  longitudinal analysis of stakeholders in the {US} and German
                  {AI} discourse on Twitter {2012–2021}},
  author       = {Richter, Vanessa and Dergacheva, Daria and Kuznetsova,
