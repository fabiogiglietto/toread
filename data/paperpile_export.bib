  journaltitle = {Eur. J. Commun.},
  publisher    = {SAGE Publications},
  issue        = {02673231261422076},
  date         = {2026-02-24},
  abstract     = {As digital authoritarianism evolves, new tools are needed to
                  analyse its increasingly subtle forms. This paper adopts a
                  longitudinal analysis of under-explored secondary sources to
                  examine coordinated inauthentic behaviour (CIB) linked to
                  Serbia's ruling party, Serbian Progressive Party (SNS). Unlike
